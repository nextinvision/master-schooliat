# Dashboard Environment Variables
# Copy this file to .env.local for local development

# Environment
NODE_ENV=development

# Backend API URL (optional for local dev)
# When unset: requests go same-origin and Next.js rewrites proxy to backend at localhost:4000.
# Production: https://api.schooliat.com
# Staging: https://staging-api.schooliat.com
# Local direct (no proxy): http://localhost:4000
# NEXT_PUBLIC_API_URL=http://localhost:4000
